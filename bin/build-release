#!/bin/bash
# Build a release archive for Homebrew distribution

set -e

cd "$(dirname "$0")/.."

VERSION="${1:-0.1.0}"
DIST_DIR="dist"
STAGING_DIR="$DIST_DIR/staging"
ZIP_NAME="vimoire-$VERSION.zip"

echo "Building release $VERSION..."

# Clean up any previous build
rm -rf "$STAGING_DIR"
mkdir -p "$STAGING_DIR"

# Copy .app bundle
cp -R platform/macos/Vimoire.app "$STAGING_DIR/"

# Copy app config as vimoire/
cp -R app "$STAGING_DIR/vimoire"

# Create the zip
cd "$STAGING_DIR"
rm -f "../$ZIP_NAME"
zip -r "../$ZIP_NAME" Vimoire.app vimoire -x "*.DS_Store"
cd ../..

# Clean up staging
rm -rf "$STAGING_DIR"

# Print sha256
echo ""
echo "Created $DIST_DIR/$ZIP_NAME"
echo ""
echo "sha256:"
shasum -a 256 "$DIST_DIR/$ZIP_NAME" | awk '{print $1}'
